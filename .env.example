# Copy this file to .env and fill in your values
# Never commit .env to version control

# MongoDB Stitch / Atlas App Services
VUE_APP_STITCH_APP_ID=your-stitch-app-id
VUE_APP_WEBHOOK_BASE_URL=https://webhooks.mongodb-stitch.com/api/client/v2.0/app/your-app-id/service/service-name/incoming_webhook

# Admin user ID (MongoDB Stitch user_id of the admin account)
VUE_APP_ADMIN_USER_ID=your-admin-user-id

# localStorage key used by the Stitch SDK for auth persistence
VUE_APP_STITCH_AUTH_KEY=__stitch.client.your-stitch-app-id.auth_info
